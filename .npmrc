# Hoist @babel/runtime so it is reachable from inside the pnpm virtual store.
# babel-preset-expo uses @babel/plugin-transform-runtime which injects
# require('@babel/runtime/helpers/...') into transformed files at runtime.
# Without hoisting, Jest cannot resolve those helpers because the transformed
# file lives inside .pnpm/react-native@.../node_modules/ and pnpm does not
# place @babel/runtime in that package's dependency namespace.
public-hoist-pattern[]=@babel/runtime
