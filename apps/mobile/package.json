{
  "name": "@trainers/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "expo export",
    "build:dev": "eas build --platform ios --profile development",
    "build:dev-device": "eas build --platform ios --profile development-device",
    "build:preview": "eas build --platform ios --profile preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --max-warnings 0 --cache",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --clean --platform ios",
    "prebuild:android": "expo prebuild --clean --platform android",
    "clean": "rm -rf .expo node_modules ios android"
  },
  "dependencies": {
    "@atproto/api": "catalog:atproto",
