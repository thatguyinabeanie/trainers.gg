    "@pkmn/dex": "catalog:pkmn",
    "@pkmn/sets": "catalog:pkmn",
    "@pkmn/sim": "catalog:pkmn",
    "@supabase/supabase-js": "catalog:supabase",
    "@tamagui/config": "^1",
    "@tamagui/web": "^1",
    "@tanstack/react-query": "catalog:tanstack",
    "@trainers/supabase": "workspace:*",
    "@trainers/utils": "workspace:*",
    "@trainers/theme": "workspace:*",
    "@trainers/validators": "workspace:*",
    "expo": "catalog:expo",
    "expo-constants": "catalog:expo",
    "expo-font": "catalog:expo",
    "expo-linking": "catalog:expo",
    "expo-router": "catalog:expo",
    "expo-secure-store": "catalog:expo",
    "expo-splash-screen": "catalog:expo",
    "expo-status-bar": "catalog:expo",
    "expo-system-ui": "catalog:expo",
    "posthog-react-native": "^4",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-native": "catalog:expo",
    "react-native-reanimated": "catalog:expo",
    "react-native-safe-area-context": "catalog:expo",
