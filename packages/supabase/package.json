{
  "name": "@trainers/supabase",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/clients/server.ts",
    "./client": "./src/clients/client.ts",
    "./mobile": "./src/clients/mobile.ts",
    "./hooks": "./src/hooks/index.ts",
    "./react-query": "./src/react-query.ts",
    "./queries": "./src/queries/index.ts",
    "./mutations": "./src/mutations/index.ts",
    "./pipeline": "./src/mutations/pipeline.ts",
    "./storage": "./src/storage/index.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "setup": "./scripts/setup-local.sh",
    "dev:setup": "./scripts/setup-local.sh",
    "dev": "./scripts/dev.sh",
    "db:start": "pnpm exec supabase start && (./scripts/ensure-cron.sh || echo '[ensure-cron] setup failed (dev convenience; see errors above) — continuing')",
    "db:stop": "pnpm exec supabase stop",
    "db:restart": "pnpm exec supabase stop && pnpm exec supabase start && (./scripts/ensure-cron.sh || echo '[ensure-cron] setup failed (dev convenience; see errors above) — continuing')",
    "db:status": "pnpm exec supabase status",
    "functions:serve": "pnpm exec supabase functions serve --no-verify-jwt --env-file .env",
    "functions:check": "deno check --config supabase/functions/deno.json --sloppy-imports $(ls supabase/functions/*/index.ts | grep -v '/api-')",
    "vendor:functions": "tsx scripts/vendor-packages.ts",
    "generate-clients": "tsx scripts/generate-clients.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --max-warnings 0 --cache",
    "typecheck": "tsc --noEmit",
    "generate-types": "pnpm exec supabase gen types typescript --local --schema public,limitless,rk9,graphql_public,private > src/types.ts",
    "generate-seed-json": "tsx scripts/generate-seed-data/generate-user-data.ts",
    "generate-seeds": "tsx scripts/generate-seed-data/index.ts",
    "db:migrate": "pnpm exec supabase migration up",
    "db:push": "pnpm exec supabase db push",
    "db:reset": "(pnpm exec supabase db reset || (docker restart supabase_kong_supabase && sleep 2 && pnpm exec supabase status)) && (./scripts/ensure-cron.sh || echo '[ensure-cron] setup failed (dev convenience; see errors above) — continuing')",
    "db:diff": "pnpm exec supabase db diff",
    "db:lint": "pnpm exec supabase db lint",
    "db:advisor": "./scripts/db-advisor.sh",
    "db:seed": "pnpm exec supabase db seed",
    "db:dump": "pnpm exec supabase db dump",
    "db:cron-check": "./scripts/cron-check.sh",
    "db:cron-diagnose": "./scripts/cron-diagnose.sh",
    "supabase": "pnpm exec supabase"
  },
  "dependencies": {
    "@supabase/supabase-js": "catalog:supabase",
    "@trainers/pokemon": "workspace:*",
    "@trainers/utils": "workspace:*",
    "@trainers/validators": "workspace:*",
    "cheerio": "^1.2.0",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@supabase/ssr": "catalog:supabase",
    "@tanstack/react-query": "catalog:tanstack",
    "expo-secure-store": "catalog:expo",
    "next": "catalog:",
    "react": "catalog:react",
    "react-native-url-polyfill": "catalog:expo"
  },
  "peerDependenciesMeta": {
    "@supabase/ssr": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-native-url-polyfill": {
      "optional": true
    }
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:",
    "@jest/globals": "catalog:testing",
    "@tanstack/react-query": "catalog:tanstack",
    "@testing-library/react": "catalog:testing",
    "@trainers/eslint-config": "workspace:*",
    "@trainers/prettier-config": "workspace:*",
    "@trainers/test-utils": "workspace:*",
    "@trainers/typescript-config": "workspace:*",
    "@types/jest": "catalog:testing",
    "@types/node": "catalog:",
    "@types/react": "~19.2.14",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "jest": "catalog:testing",
    "jest-environment-jsdom": "catalog:testing",
    "jest-junit": "catalog:testing",
    "prettier": "catalog:",
    "supabase": "catalog:supabase",
    "ts-jest": "catalog:testing",
    "ts-node": "catalog:testing",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@trainers/prettier-config"
}
